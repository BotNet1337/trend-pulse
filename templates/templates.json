[
  {
    "eventName": "auth.verify_email",
    "templatePath": "auth/verify-email",
    "subject": "Verify your Foresignal email",
    "schema": {
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "verifyUrl": { "type": "string" },
        "expiresAt": { "type": "string" }
      },
      "required": ["userName", "verifyUrl", "expiresAt"]
    },
    "previewDefaults": {
      "userName": "Alex",
      "verifyUrl": "https://app.trendpulse.local/auth/email/confirm?token=preview",
      "expiresAt": "24 hours from now"
    }
  },
  {
    "eventName": "auth.reset_password",
    "templatePath": "auth/reset-password",
    "subject": "Reset your Foresignal password",
    "schema": {
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "resetUrl": { "type": "string" },
        "expiresAt": { "type": "string" }
      },
      "required": ["userName", "resetUrl", "expiresAt"]
    },
    "previewDefaults": {
      "userName": "Alex",
      "resetUrl": "https://app.trendpulse.local/auth/reset-password?token=preview",
      "expiresAt": "1 hour from now"
    }
  },
  {
    "eventName": "auth.welcome",
    "templatePath": "auth/welcome",
    "subject": "Welcome to Foresignal, {{userName}}!",
    "schema": {
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "dashboardUrl": { "type": "string" },
        "unsubscribeUrl": { "type": "string" }
      },
      "required": ["userName", "dashboardUrl"]
    },
    "previewDefaults": {
      "userName": "Alex",
      "dashboardUrl": "https://app.trendpulse.local/dashboard",
      "unsubscribeUrl": "https://app.trendpulse.local/api/v1/email/unsubscribe?token=preview"
    }
  },
  {
    "eventName": "auth.email_change_requested",
    "templatePath": "auth/email-change-requested",
    "subject": "Confirm your new Foresignal email",
    "schema": {
      "type": "object",
      "properties": {
        "oldEmail": { "type": "string" },
        "newEmail": { "type": "string" },
        "confirmUrl": { "type": "string" },
        "expiresAt": { "type": "string" }
      },
      "required": ["oldEmail", "newEmail", "confirmUrl", "expiresAt"]
    },
    "previewDefaults": {
      "oldEmail": "old@example.com",
      "newEmail": "new@example.com",
      "confirmUrl": "https://app.trendpulse.local/auth/email/confirm-change?token=preview",
      "expiresAt": "24 hours from now"
    }
  },
  {
    "eventName": "auth.email_changed",
    "templatePath": "auth/email-changed",
    "subject": "Your Foresignal email was changed",
    "schema": {
      "type": "object",
      "properties": {
        "oldEmail": { "type": "string" },
        "newEmail": { "type": "string" }
      },
      "required": ["oldEmail", "newEmail"]
    },
    "previewDefaults": {
      "oldEmail": "old@example.com",
      "newEmail": "new@example.com"
    }
  },
  {
    "eventName": "billing.renewal",
    "templatePath": "billing/renewal",
    "subject": "Your Foresignal subscription is expiring soon",
    "schema": {
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "planName": { "type": "string" },
        "daysLeft": { "type": ["number", "string"] },
        "renewUrl": { "type": "string" }
      },
      "required": ["userName", "planName", "daysLeft", "renewUrl"]
    },
    "previewDefaults": {
      "userName": "Alex",
      "planName": "pro",
      "daysLeft": 3,
      "renewUrl": "https://app.trendpulse.local/billing"
    }
  },
  {
    "eventName": "lifecycle.weekly_digest",
    "templatePath": "lifecycle/weekly-digest",
    "subject": "Your weekly Foresignal digest",
    "schema": {
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "topic": { "type": "string" },
              "score": { "type": "string" },
              "packSlug": { "type": ["string", "null"] }
            },
            "required": ["topic", "score"]
          }
        },
        "dashboardUrl": { "type": "string" },
        "unsubscribeUrl": { "type": "string" }
      },
      "required": ["userName", "items", "dashboardUrl", "unsubscribeUrl"]
    },
    "previewDefaults": {
      "userName": "Alex",
      "items": [
        { "topic": "AI model release roundup", "score": "97.4", "packSlug": "ai-tech" },
        { "topic": "Crypto market swing", "score": "91.2", "packSlug": null }
      ],
      "dashboardUrl": "https://app.trendpulse.local/watchlists",
      "unsubscribeUrl": "https://app.trendpulse.local/api/v1/email/unsubscribe?token=preview"
    }
  },
  {
    "eventName": "lifecycle.win_back",
    "templatePath": "lifecycle/win-back",
    "subject": "Your Foresignal packs have been quiet",
    "schema": {
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "watchlistsUrl": { "type": "string" },
        "unsubscribeUrl": { "type": "string" }
      },
      "required": ["userName", "watchlistsUrl", "unsubscribeUrl"]
    },
    "previewDefaults": {
      "userName": "Alex",
      "watchlistsUrl": "https://app.trendpulse.local/watchlists",
      "unsubscribeUrl": "https://app.trendpulse.local/api/v1/email/unsubscribe?token=preview"
    }
  },
  {
    "eventName": "billing.underpaid",
    "templatePath": "billing/underpaid",
    "subject": "Complete your Foresignal payment",
    "schema": {
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "planName": { "type": "string" },
        "amountDue": { "type": ["number", "string", "null"] },
        "payUrl": { "type": "string" }
      },
      "required": ["userName", "planName", "payUrl"]
    },
    "previewDefaults": {
      "userName": "Alex",
      "planName": "pro",
      "amountDue": "9.00",
      "payUrl": "https://nowpayments.io/payment/?iid=preview"
    }
  }
]
