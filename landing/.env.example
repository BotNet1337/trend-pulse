VITE_BRAND_NAME=PostBolt
VITE_SITE_URL=https://postbolt.org

# Central email domain. Defaults to the hostname of VITE_SITE_URL.
# Override only if email is served from a different host than the website.
# VITE_DOMAIN_NAME=postbolt.org

# Support (main help) mailbox. Everything below falls back to this one by default.
# VITE_SUPPORT_EMAIL=support@postbolt.org
# VITE_CONTACT_EMAIL=support@postbolt.org   # alias for legacy code

# Specialised mailboxes — uncomment ONLY when you have separate inboxes.
# Until then, privacy/abuse/security requests all land in support@.
# VITE_PRIVACY_EMAIL=privacy@postbolt.org
# VITE_ABUSE_EMAIL=abuse@postbolt.org
# VITE_SECURITY_EMAIL=security@postbolt.org

# Legal entity details (used in Privacy Policy, Terms of Service, DPA, etc.)
# VITE_LEGAL_ENTITY_NAME=Sole Proprietor (FOP) Kharchenko Yaroslav Oleksandrovych
# VITE_LEGAL_ENTITY_SHORT=FOP Kharchenko Y.O.
# VITE_LEGAL_ADDRESS=Komunalna St 16, Hlukhiv, Sumy Oblast, 41400, Ukraine
# VITE_LEGAL_COUNTRY_CODE=UA
# VITE_LEGAL_JURISDICTION=Ukraine
# VITE_LEGAL_GOVERNING_LAW=the laws of Ukraine
# VITE_LEGAL_COURTS=the competent courts located in Ukraine
# VITE_LEGAL_EFFECTIVE_DATE=April 8, 2026
