# release/version.env — pinned production images (committed, non-secret).
# THE single place where image tags live (Invariant: no `latest`/floating tags).
# Used for compose interpolation (image tags) ONLY — not container runtime env.
#
# ${APP_VERSION} is interpolated by Ansible at deploy time (the git ref/tag being
# deployed). The committed default below tracks the last released tag; Ansible
# overrides it via `-e app_version=<tag>` so the built/deployed images carry the
# exact release version (rolling-update trigger + Sentry `release` correlation).
#
# Differs from development/version.env: app images are tagged :${APP_VERSION}
# (prod, not :dev), and mailpit is intentionally absent (prod SMTP = Resend).

# --- Build-arg pins (mirror development/version.env; deterministic builds) ---
PYTHON_VERSION=3.12
PG_VERSION=16
UV_VERSION=0.11.12
NODE_VERSION=22.15.1

# --- Third-party runtime images (pinned, non-floating) ---
PGVECTOR_IMAGE=pgvector/pgvector:pg16
REDIS_VERSION=7
NGINX_VERSION=1.27
AWS_CLI_VERSION=2.22.35
AWS_CLI_IMAGE=amazon/aws-cli:2.22.35

# --- Application version (overridden by Ansible: -e app_version=<tag>) ---
# Default = the last released tag. Keep in sync with RELEASE.md on each release.
APP_VERSION=v0.1.0

# --- First-party images, tagged with the release version (built on host) ---
# Lean app image — api/beat/migration_runner (core deps only, no torch).
APP_IMAGE=trendpulse-backend:${APP_VERSION}
# Worker image — core + `ml` (sentence-transformers/torch) for the embed pipeline.
APP_IMAGE_ML=trendpulse-backend-ml:${APP_VERSION}
# Frontend SPA (React + SSR).
FRONTEND_IMAGE=trendpulse-frontend:${APP_VERSION}
# Templates service — Node/Fastify + react-email (internal-only, port 3100).
TEMPLATES_IMAGE=trendpulse-templates:${APP_VERSION}
