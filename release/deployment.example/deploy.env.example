# release/deployment.example/deploy.env.example
#
# TEMPLATE for release/env/deploy.env (NON-SECRET production runtime values).
# The real file is rendered by the Ansible `env` role from group_vars (single
# source of truth, ADR-005 §4) into release/env/deploy.env on the host and is
# gitignored. This committed template documents every key so the bundle is
# self-describing for a manual / disaster-recovery render.
#
# For a manual local render (e.g. to test `make render` without Ansible):
#   cp deployment.example/deploy.env.example     env/deploy.env
#   cp deployment.example/sensitive.env.example  env/sensitive.env
#   # fill the placeholders, then: make validate render

# --- Postgres (DSN assembled from parts; password is in sensitive.env) ---
POSTGRES_DB=trendpulse
POSTGRES_USER=trendpulse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis broker/result backend ---
REDIS_URL=redis://redis:6379/0

# --- Network names (overlay; match docker-compose.yml) ---
EDGE_NETWORK=edge
INTERNAL_NETWORK=internal
POSTGRES_NETWORK=postgres_net
REDIS_NETWORK=redis_net

# --- App runtime flags (PROD values) ---
TRENDPULSE_DEBUG=false
JWT_LIFETIME_SECONDS=3600
# PROD: cookie MUST be Secure (served over HTTPS). Dev is false.
AUTH_COOKIE_SECURE=true
# SECURITY (TASK-019): the full OpenAPI schema/Swagger UI MUST be off in prod.
SWAGGER_ENABLE=false

# --- Observability (Sentry DSN is a secret → sensitive.env) ---
ENVIRONMENT=prod
# RELEASE = the deployed git tag (app_version). Sentry filters issues by release.
RELEASE=v0.1.0
SENTRY_TRACES_SAMPLE_RATE=0.0

# --- Email: templates service + SMTP transport (PROD = Resend) ---
TEMPLATES_SERVICE_URL=http://templates:3100
# Resend SMTP relay (creds in sensitive.env). STARTTLS MUST be on in prod.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_FROM=TrendPulse <noreply@example.com>
SMTP_STARTTLS=true

# --- Domain (drives the prod nginx TLS config via envsubst) ---
DOMAIN=example.com

# --- Frontend / deeplinks (HTTPS domain) ---
FRONTEND_DOMAIN=app.example.com
BASE_URL=https://app.example.com
FRONTEND_BASE_URL=https://app.example.com

# --- Object storage (creds in sensitive.env) ---
S3_ENDPOINT=https://nbg1.your-objectstorage.com
S3_REGION=nbg1
S3_BUCKET=trendpulse-backups

# --- TG pool health target (raise to 3 once pool is filled) ---
POOL_MIN_HEALTHY=1

# --- Alert feedback buttons — public HTTPS base URL (empty = disabled) ---
PUBLIC_BASE_URL=https://example.com
