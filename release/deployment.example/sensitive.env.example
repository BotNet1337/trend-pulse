# release/deployment.example/sensitive.env.example
#
# TEMPLATE for release/env/sensitive.env (SECRETS). The real file is rendered by
# the Ansible `env` role from the decrypted ops/ansible/vault/sensitive.vault.yml
# into release/env/sensitive.env (mode 0600, owner deploy) and is gitignored.
#
# NEVER commit real values. Placeholders below are NOT valid secrets — replace
# every CHANGE_ME before any manual render. In normal operation Ansible fills
# these from the vault; you only touch this file for disaster recovery.

# --- Postgres ---
POSTGRES_PASSWORD=CHANGE_ME

# --- Auth (ADR-003). Generate ≥32-byte high-entropy values for prod. ---
JWT_SECRET=CHANGE_ME
OAUTH_STATE_SECRET=CHANGE_ME
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# --- Billing (NOWPayments) ---
NOWPAYMENTS_API_KEY=CHANGE_ME
NOWPAYMENTS_IPN_SECRET=CHANGE_ME

# --- Telegram collector (MTProto) ---
# TELEGRAM_API_ID/HASH also power the admin QR-login onboarding (EPIC-TG-QR-POOL):
# a superuser scans a QR at /admin/pool to mint a NEW session, then pastes it into
# TELEGRAM_POOL_SESSIONS below and redeploys (the pool is never hot-swapped).
TELEGRAM_API_ID=CHANGE_ME
TELEGRAM_API_HASH=CHANGE_ME
TELEGRAM_POOL_SESSIONS=CHANGE_ME
# Optional: seconds a QR-login stays valid before it expires (default 300).
# QR_LOGIN_TIMEOUT_SECONDS=300

# --- Twitter/X source (TASK-031; empty = Twitter ingest off) ---
# App-only Bearer token (X API v2). Pay-per-use ($0.005/read) — the collector
# enforces a monthly read budget. See docs/research/twitter-source-research-brief.md.
TWITTER_BEARER_TOKEN=

# --- Reddit source (TASK-092; all three empty = Reddit ingest off) ---
# OAuth2 application-only (client_credentials). Read-only public data is FREE — no
# per-read price, so NO read budget (only rate-limit backoff). Reddit REQUIRES a
# unique User-Agent (e.g. "trendpulse:vX.Y (by /u/yourname)"). Issue an app at
# https://www.reddit.com/prefs/apps. See docs/reddit-data-guide.md.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=

# --- Observability (empty = Sentry off) ---
SENTRY_DSN=

# --- SMTP credentials (Resend). Empty = no auth. ---
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME

# --- Frontend SSR cookie signing secret (≥16 chars) ---
FRONTEND_COOKIE_SECRET=CHANGE_ME

# --- Object storage credentials (pg-backup, TASK-034/056) ---
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME

# --- Ops self-alert bot (empty = self-alert off) ---
OPS_TELEGRAM_BOT_TOKEN=
OPS_TELEGRAM_CHAT_ID=

# --- Showcase autopost bot (empty = autoposting off) ---
SHOWCASE_BOT_TOKEN=
SHOWCASE_CHANNEL_CHAT_ID=

# --- At-rest field encryption key (Fernet, 32-byte urlsafe-base64, TASK-032) ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# LOSS = permanent loss of encrypted user tokens. Required for production.
FIELD_ENCRYPTION_KEY=CHANGE_ME
