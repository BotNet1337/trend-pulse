# Terraform local state and plugins (state is local per environment, NEVER in git — ADR-005)
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log

# tfvars may contain secrets — ignore all EXCEPT the committed *.example
*.tfvars
*.tfvars.json
!*.tfvars.example

# Saved outputs (may reveal infra details)
outputs.json
tf_outputs.json
