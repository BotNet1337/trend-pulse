# Terraform local state, plugins, and tfvars (which may carry secrets).
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# tfvars may contain secrets — ignore all EXCEPT the committed *.example.
*.tfvars
*.tfvars.json
!*.tfvars.example

# Backend config passed at init time (may carry creds).
*.backend.hcl

# Local backend override used during verify/AC2 (not for production use).
backend_override.tf
*_override.tf
