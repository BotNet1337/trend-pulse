# Cloudflare (https://dash.cloudflare.com/profile/api-tokens — see variables.tf for permissions)
cloudflare_api_token  = "YOUR_CLOUDFLARE_API_TOKEN"
cloudflare_account_id = "YOUR_ACCOUNT_ID"

# Domain (registrar: GoDaddy — set Cloudflare NS there after apply)
domain = "foresignal.biz"

# Email routing — all addresses forward to your real mailbox
email_catch_all_destination = "owner@example.com"
email_dmarc_rua             = "owner@example.com"
email_dmarc_policy          = "none"

email_routes = {
  support  = "owner@example.com"
  privacy  = "owner@example.com"
  abuse    = "owner@example.com"
  security = "owner@example.com"
}

# Resend SMTP (outbound email) — enable later, when SMTP creds are provisioned:
# resend_enabled    = true
# resend_dkim_value = "p=MIGfMA0GCSq..."  # Resend → Domains → Add Domain → DNS Records

# Sentry (observability) — enable later, when you have an org auth token.
# Token scopes: project:read/write/admin, team:read/write, org:read.
# After apply: terraform output -raw sentry_dsn  → put in the ansible vault.
# sentry_enabled      = true
# sentry_auth_token   = "sntrys_xxx"          # Sentry → Settings → Auth Tokens
# sentry_organization = "your-org-slug"       # Settings → General → Organization Slug
# sentry_platform     = "python"              # or "node"
