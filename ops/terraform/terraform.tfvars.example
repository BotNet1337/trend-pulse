# Copy to terraform.tfvars (GITIGNORED) and fill in. Secrets (s3_access_key,
# s3_secret_key) are best supplied via TF_VAR_* env vars instead of a file.
# NEVER commit a real terraform.tfvars — only this *.example is tracked.

# --- Placement / sizing ---
region    = "fra1"
vps_size  = "s-2vcpu-4gb"
vps_image = "ubuntu-24-04-x64"

# --- DNS ---
domain        = "trendpulse.example"
app_subdomain = "app"

# --- SSH / firewall allowlist (least-privilege — replace with YOUR office/VPN CIDRs) ---
ssh_key_fingerprints = ["aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99"]
ssh_allowlist_cidrs  = ["203.0.113.4/32"]

# --- Hetzner Object Storage (S3-compatible, TASK-056) ---
# Endpoint format: https://<region>.your-objectstorage.com
# Available Hetzner regions: fsn1 (Falkenstein), nbg1 (Nuremberg), hel1 (Helsinki)
s3_endpoint   = "https://fsn1.your-objectstorage.com"
s3_region     = "fsn1"  # IMPORTANT: must match the datacenter slug in s3_endpoint (fsn1/nbg1/hel1, NOT "eu-central")
# Credentials: Hetzner Console → project TrendPulse → Object Storage → Manage credentials
# Keep secrets in TF_VAR_s3_access_key / TF_VAR_s3_secret_key env vars or this gitignored file.
s3_access_key = "XXXXXXXXXXXXXXXXXXXX"
s3_secret_key = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Bucket name (Hetzner Object Storage namespace is per-region; rename if taken):
s3_backup_bucket_name = "trendpulse-backups"
# How many days to keep postgres/ backups before lifecycle expiry (default: 30):
# backup_expire_after_days = 30
