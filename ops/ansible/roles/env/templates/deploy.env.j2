{{ ansible_managed | comment }}
# deploy.env (non-secret) — rendered from ops/ansible/group_vars/* by
# `make ansible-unpack` (ADR-005 §4). DO NOT edit by hand; not committed.
POSTGRES_DB={{ postgres_db }}
POSTGRES_USER={{ postgres_user }}
POSTGRES_HOST={{ postgres_host }}
POSTGRES_PORT={{ postgres_port }}
REDIS_URL={{ redis_url }}
EDGE_NETWORK={{ edge_network }}
INTERNAL_NETWORK={{ internal_network }}
POSTGRES_NETWORK={{ postgres_network }}
REDIS_NETWORK={{ redis_network }}
TRENDPULSE_DEBUG={{ trendpulse_debug }}
JWT_LIFETIME_SECONDS={{ jwt_lifetime_seconds }}
AUTH_COOKIE_SECURE={{ auth_cookie_secure }}
SWAGGER_ENABLE={{ swagger_enable }}
# TASK-024: Observability -- non-secret Sentry settings; DSN is in sensitive.vault.
# RELEASE tags every Sentry event with the deployed version (= app_version, the
# git ref/tag the deploy playbook checks out) so issues filter by deploy stage.
ENVIRONMENT={{ environment }}
RELEASE={{ app_version }}
SENTRY_TRACES_SAMPLE_RATE={{ sentry_traces_sample_rate }}
# TASK-025: Email -- templates service + SMTP transport (generic, no vendor lock-in).
# Dev defaults -> templates compose service + mailpit catch-all SMTP.
TEMPLATES_SERVICE_URL={{ templates_service_url }}
SMTP_HOST={{ smtp_host }}
SMTP_PORT={{ smtp_port }}
SMTP_FROM={{ smtp_from }}
SMTP_STARTTLS={{ smtp_starttls }}
# Frontend URL injected into email deeplinks (TASK-026 verify-email + reset-password).
# FRONTEND_BASE_URL must be the HTTPS origin in prod (e.g. https://app.trendpulse.io).
# Dev default in config.py → http://localhost (nginx on :80); set to real domain here.
FRONTEND_DOMAIN={{ frontend_domain }}
BASE_URL={{ base_url }}
FRONTEND_BASE_URL={{ base_url }}
# TASK-056: Hetzner Object Storage (non-secret). S3_ACCESS_KEY/S3_SECRET_KEY are in sensitive.env.
# Override s3_endpoint in group_vars/prod.yml for the correct region endpoint.
S3_ENDPOINT={{ s3_endpoint }}
S3_REGION={{ s3_region }}
S3_BUCKET={{ s3_bucket }}
# TASK-035: TG pool health -- operational target (non-secret). Code default=3.
# Prod sets POOL_MIN_HEALTHY=1 while only one session is provisioned (no spam);
# raise to 3 in prod.yml once 3+ sessions are added.
POOL_MIN_HEALTHY={{ pool_min_healthy }}
# TASK-042: Alert feedback 👍/👎 — publicly reachable deployment URL for signed token
# buttons. Empty string (default) disables feedback buttons (graceful degradation).
# Prod MUST set this to the HTTPS domain so buttons work in live Telegram alerts.
PUBLIC_BASE_URL={{ public_base_url }}
