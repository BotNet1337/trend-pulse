{{ ansible_managed | comment }}
# sensitive.env (SECRETS, gitignored) — decrypted from ops/ansible/vault/
# sensitive.vault.yml by `make ansible-unpack` (ADR-005 §4). DO NOT edit/commit.
POSTGRES_PASSWORD={{ vault_postgres_password }}
JWT_SECRET={{ vault_jwt_secret }}
OAUTH_STATE_SECRET={{ vault_oauth_state_secret }}
GOOGLE_CLIENT_ID={{ vault_google_client_id }}
GOOGLE_CLIENT_SECRET={{ vault_google_client_secret }}
NOWPAYMENTS_API_KEY={{ vault_nowpayments_api_key }}
NOWPAYMENTS_IPN_SECRET={{ vault_nowpayments_ipn_secret }}
TELEGRAM_API_ID={{ vault_telegram_api_id }}
TELEGRAM_API_HASH={{ vault_telegram_api_hash }}
TELEGRAM_POOL_SESSIONS={{ vault_telegram_pool_sessions }}
# TASK-024: Sentry DSN -- secret; empty = Sentry off. Optional (unlike the boot
# secrets above), so `default('')` keeps `make ansible-unpack` working on hosts
# where the vault key isn't set yet. Set `vault_sentry_dsn` in the vault to enable.
SENTRY_DSN={{ vault_sentry_dsn | default('') }}
# TASK-025: SMTP credentials -- secret; empty = no auth (mailpit dev mode).
# Set vault_smtp_user / vault_smtp_password for production SMTP providers.
SMTP_USER={{ vault_smtp_user | default('') }}
SMTP_PASSWORD={{ vault_smtp_password | default('') }}
# TASK-029: Frontend SSR cookie signing secret (≥16 chars).
# Used by @fastify/cookie to sign session cookies on the SSR server.
# Set vault_frontend_cookie_secret in the vault for production.
FRONTEND_COOKIE_SECRET={{ vault_frontend_cookie_secret | default('') }}
# TASK-056: Hetzner Object Storage credentials -- secret; used by pg-backup (TASK-034).
# Create credentials in Hetzner Console → project TrendPulse → Object Storage → Manage credentials.
# Set vault_s3_access_key / vault_s3_secret_key in the vault.
S3_ACCESS_KEY={{ vault_s3_access_key | default('') }}
S3_SECRET_KEY={{ vault_s3_secret_key | default('') }}
# TASK-035: Ops self-alert bot credentials -- secret; empty = self-alert off (metric only).
# Set vault_ops_telegram_bot_token / vault_ops_telegram_chat_id in the vault to enable.
# The bot must have permission to send messages to the ops chat.
OPS_TELEGRAM_BOT_TOKEN={{ vault_ops_telegram_bot_token | default('') }}
OPS_TELEGRAM_CHAT_ID={{ vault_ops_telegram_chat_id | default('') }}
# TASK-044: Showcase autopost bot credentials -- secret; empty = autoposting off.
# Set vault_showcase_bot_token / vault_showcase_channel_chat_id in the vault to enable.
# The bot must be an admin of the public showcase TG channel.
# In MVP: may reuse the same bot token as OPS_TELEGRAM_BOT_TOKEN (bot serves two chats).
SHOWCASE_BOT_TOKEN={{ vault_showcase_bot_token | default('') }}
SHOWCASE_CHANNEL_CHAT_ID={{ vault_showcase_channel_chat_id | default('') }}
