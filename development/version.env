# development/version.env — pinned deps/images (committed, non-secret).
# Used for compose interpolation (image tags) and Dockerfile build-args ONLY,
# not container runtime env. Change a version HERE and nowhere else.
# No `latest`/floating tags anywhere — builds are deterministic everywhere.
PYTHON_VERSION=3.12
PG_VERSION=16
PGVECTOR_IMAGE=pgvector/pgvector:pg16
REDIS_VERSION=7
NGINX_VERSION=1.27
UV_VERSION=0.11.12
# Shared application image tag (built once, reused by api/worker/beat/migration_runner).
APP_IMAGE=trendpulse-backend:dev
