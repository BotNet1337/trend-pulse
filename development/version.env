# development/version.env — pinned deps/images (committed, non-secret).
# Used for compose interpolation (image tags) and Dockerfile build-args ONLY,
# not container runtime env. Change a version HERE and nowhere else.
# No `latest`/floating tags anywhere — builds are deterministic everywhere.
PYTHON_VERSION=3.12
PG_VERSION=16
PGVECTOR_IMAGE=pgvector/pgvector:pg16
REDIS_VERSION=7
NGINX_VERSION=1.27
UV_VERSION=0.11.12
# Lean app image — api/beat/migration_runner (core deps only, no torch).
APP_IMAGE=trendpulse-backend:dev
# Worker image — core + `ml` (sentence-transformers/torch) for the embed pipeline
# (task-007). Built from the SAME Dockerfile with INSTALL_ML=true.
APP_IMAGE_ML=trendpulse-backend-ml:dev
# Frontend SPA (React + SSR). Pin the same LTS used in local dev (nvm).
NODE_VERSION=22.15.1
# Frontend image — multi-stage build (deps → builder → production/static).
FRONTEND_IMAGE=trendpulse-frontend:dev
# Templates service — Node/Fastify + react-email (internal-only, port 3100).
TEMPLATES_IMAGE=trendpulse-templates:dev
# Mailpit — local catch-all SMTP sink + web UI. Pin the tag for reproducible builds.
MAILPIT_IMAGE=axllent/mailpit:v1.21
# AWS CLI image for pg_backup uploader + restore-check (TASK-034).
# Pin a concrete version — never `latest`. See development/compose/pg-backup.yml.
AWS_CLI_VERSION=2.22.35
AWS_CLI_IMAGE=amazon/aws-cli:2.22.35
