{
  "name": "trendpulse-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/main.ts",
    "build": "cross-env NODE_ENV=production tsc -b && vite build",
    "start": "cross-env NODE_ENV=production tsx --tsconfig tsconfig.app.json server/main.ts",
    "gen:api": "openapi-typescript src/shared/api/openapi.json -o src/shared/api/gen.types.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/http-proxy": "^11.3.0",
    "@fastify/middie": "^9.0.3",
    "@fastify/static": "^9.1.3",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.9",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@tanstack/react-router": "^1.136.5",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.553.0",
    "pino-pretty": "^13.1.2",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.66.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.4.0",
    "tsx": "^4.20.6",
    "usehooks-ts": "^3.1.1",
    "uuid": "^13.0.0",
    "zod": "3.25.75",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/router-cli": "^1.136.9",
    "@tanstack/router-devtools": "^1.136.5",
    "@tanstack/router-plugin": "^1.136.9",
